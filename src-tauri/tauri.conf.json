{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "prisma-desktop",
  "version": "0.1.0",
  "identifier": "dev.cservinl.prisma-desktop",
  "build": {
    "devUrl": "http://127.0.0.1:8765/app",
    "frontendDist": "http://127.0.0.1:8765/app"
  },
  "app": {
    "windows": [
      {
        "title": "Prisma",
        "url": "http://127.0.0.1:8765/app",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:8765; script-src 'self' 'unsafe-inline' http://127.0.0.1:8765; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://127.0.0.1:8765 ws://127.0.0.1:8765; img-src 'self' data: http://127.0.0.1:8765; frame-src http://127.0.0.1:8765"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
